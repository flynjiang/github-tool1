# 代理模式 / Proxy Mode
# ─────────────────────────────────────────────
# direct   — 直连 GitHub（无需代理，适合海外或已有全局代理）
# steam++  — 通过 Steam++/Watt Toolkit 本地代理（127.0.0.1:443）
# custom   — 自定义代理地址（需设置 PROXY_HOST 和 PROXY_PORT）
#
# 默认: direct
PROXY_MODE=direct

# 自定义代理地址（仅 PROXY_MODE=custom 时生效）
PROXY_HOST=127.0.0.1
PROXY_PORT=7890
